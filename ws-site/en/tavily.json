                      "south sudan",
                      "spain",
                      "sri lanka",
                      "sudan",
                      "sweden",
                      "switzerland",
                      "syria",
                      "taiwan",
                      "tajikistan",
                      "tanzania",
                      "thailand",
                      "togo",
                      "trinidad and tobago",
                      "tunisia",
                      "turkey",
                      "turkmenistan",
                      "uganda",
                      "ukraine",
                      "united arab emirates",
                      "united kingdom",
                      "united states",
                      "uruguay",
                      "uzbekistan",
                      "venezuela",
                      "vietnam",
                      "yemen",
                      "zambia",
                      "zimbabwe"
                    ]
                  },
                  "auto_parameters": {
                    "type": "boolean",
                    "default": false,
                    "description": "When enabled, let Tavily infer and set search parameters automatically from the query content."
                  },
                  "include_usage": {
                    "type": "boolean",
                    "default": false,
                    "description": "When enabled, include credit usage details for this request in the response."
                  }
                },
                "required": [
                  "query"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "query": {
                      "type": "string",
                      "description": "Echo of the search query that was executed."
                    },
                    "answer": {
                      "type": "string",
                      "description": "Short LLM-generated answer to the query; present only when an answer was requested."
                    },
                    "images": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "url": {
                            "type": "string",
                            "description": "Direct URL of the matched image."
                          },
                          "description": {
                            "type": "string",
                            "description": "Caption describing the image; present only when image descriptions were requested."
                          }
                        }
                      },
                      "description": "Images matched by the query; present only when image search was requested."
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "title": {
                            "type": "string",
                            "description": "Title of the result page."
                          },
                          "url": {
                            "type": "string",
                            "description": "URL of the result page."
                          },
                          "content": {
                            "type": "string",
                            "description": "Most relevant text snippet extracted from the result page."
                          },
                          "score": {
                            "type": "number",
                            "format": "float",
                            "description": "Relevance score of the result to the query; higher means more relevant."
                          },
                          "favicon": {
                            "type": "string",
                            "description": "Favicon URL of the result's source site; present only when favicons were requested."
                          }
                        }
                      },
                      "description": "Ranked list of web search results."
                    },
                    "response_time": {
                      "type": "number",
                      "format": "float",
                      "description": "Server-side time taken to complete the request, in seconds."
                    },
                    "usage": {
                      "type": "object",
                      "properties": {
                        "credits": {
                          "type": "integer",
                          "description": "Number of credits consumed by this request."
                        }
                      },
                      "description": "Credit usage for this request; present only when usage reporting was requested."
                    },
                    "request_id": {
                      "type": "string",
                      "description": "Unique identifier of this request, useful for tracing and support."
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Run a web search through Tavily and return ranked results, with optional LLM-generated answer, images, raw page content and credit usage. Tune relevance and latency via search_depth, and narrow scope with topic, time window, domain and country filters."
      }
    },
    "/tavily/extract": {
      "post": {
        "tags": [
          "https://docs.tavily.com/documentation/api-reference/endpoint/extract"
        ],
        "summary": "Extract web page content from specified URLs using Tavily Extract.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "urls": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "One or more web page URLs to extract content from.",
                    "example": [
                      "https://en.wikipedia.org/wiki/Artificial_intelligence"
                    ]
                  },
                  "query": {
                    "type": "string",
                    "description": "Statement of intent used to rerank the extracted content chunks so the most relevant ones surface first."
                  },
                  "chunks_per_source": {
                    "type": "integer",
                    "default": 3,
                    "description": "How many of the most relevant text chunks to keep from each URL.",
                    "minimum": 1,
                    "maximum": 5
                  },
                  "extract_depth": {
                    "type": "string",
                    "enum": [
                      "basic",
                      "advanced"
                    ],
                    "default": "basic",
                    "description": "Extraction thoroughness: `basic` is faster and lighter, `advanced` parses more thoroughly at higher latency and cost."
                  },
                  "include_images": {
                    "type": "boolean",
                    "default": false,
                    "description": "When enabled, also return images found on the extracted pages."
                  },
                  "include_favicon": {
                    "type": "boolean",
                    "default": false,
                    "description": "When enabled, include the favicon URL of each extracted page."
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "markdown",
                      "text"
                    ],
                    "default": "markdown",
                    "description": "Output format of the extracted content: `markdown` preserves structure, `text` returns plain text."
                  },
                  "timeout": {
                    "type": "number",
                    "format": "float",
                    "description": "Maximum time to wait for a URL to be fetched and extracted, in seconds.",
                    "minimum": 1,
                    "maximum": 60
                  },
                  "include_usage": {
                    "type": "boolean",
                    "default": false,
                    "description": "When enabled, include credit usage details for this request in the response."
                  }
                },
                "required": [
                  "urls"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Extraction results returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "url": {
                            "type": "string",
                            "description": "URL whose content was extracted."
                          },
                          "raw_content": {
                            "type": "string",
                            "description": "Cleaned, parsed content of the page in the requested format."
                          },
                          "favicon": {
                            "type": "string",
                            "description": "Favicon URL of the extracted page; present only when favicons were requested."
                          }
                        }
                      },
                      "description": "Successfully extracted pages, one entry per URL."
                    },
                    "failed_results": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "URLs that could not be fetched or extracted."
                    },
                    "response_time": {
                      "type": "number",
                      "format": "float",
                      "description": "Server-side time taken to complete the request, in seconds."
                    },
                    "usage": {
                      "type": "object",
                      "properties": {
                        "credits": {
                          "type": "integer",
                          "description": "Number of credits consumed by this request."
                        }
                      },
                      "description": "Credit usage for this request; present only when usage reporting was requested."
                    },
                    "request_id": {
                      "type": "string",
                      "description": "Unique identifier of this request, useful for tracing and support."
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Fetch and clean the readable content of one or more URLs through Tavily Extract, returning parsed page text plus optional images and credit usage. Use query to rerank the extracted chunks by relevance to your intent."
      }
    },
    "/tavily/crawl": {
      "post": {
        "tags": [
          "https://docs.tavily.com/documentation/api-reference/endpoint/crawl"
        ],
        "summary": "Graph-based website traversal tool using Tavily Crawl.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "description": "Root URL where the crawl begins.",
                    "example": "docs.tavily.com"
                  },
                  "instructions": {
                    "type": "string",
                    "description": "Natural-language guidance telling the crawler what content to prioritize while traversing links."
                  },
                  "chunks_per_source": {
                    "type": "integer",
                    "default": 3,
                    "description": "How many of the most relevant text chunks to keep from each crawled page.",
                    "minimum": 1,
                    "maximum": 5
                  },
                  "max_depth": {
                    "type": "integer",
                    "default": 1,
                    "description": "How many link hops away from the root URL the crawler may go.",
                    "minimum": 1,
                    "maximum": 5
                  },
                  "max_breadth": {
                    "type": "integer",
                    "default": 20,
                    "description": "How many links the crawler may follow at each level of the link tree.",
                    "minimum": 1,
                    "maximum": 500
                  },
                  "limit": {
                    "type": "integer",
                    "default": 50,
                    "description": "Total number of links the crawler will process before it stops.",
                    "minimum": 1
                  },
                  "select_paths": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Regex patterns; only URLs whose path matches are crawled."
                  },
                  "select_domains": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Regex patterns; crawling is restricted to matching domains or subdomains."
                  },
                  "exclude_paths": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Regex patterns; URLs whose path matches are skipped."
                  },
                  "exclude_domains": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Regex patterns; matching domains or subdomains are skipped."
                  },
                  "allow_external": {
                    "type": "boolean",
                    "default": true,
                    "description": "When enabled, links pointing to external domains are also kept in the results."
                  },
                  "include_images": {
                    "type": "boolean",
                    "default": false,
                    "description": "When enabled, also return images found while crawling."
                  },
                  "extract_depth": {
                    "type": "string",
                    "enum": [
                      "basic",
                      "advanced"
                    ],
                    "default": "basic",
                    "description": "Extraction thoroughness for each crawled page: `basic` is faster and lighter, `advanced` parses more thoroughly at higher latency and cost."
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "markdown",
                      "text"
                    ],
                    "default": "markdown",
                    "description": "Output format of the extracted page content: `markdown` preserves structure, `text` returns plain text."
                  },
                  "include_favicon": {
                    "type": "boolean",
                    "default": false,
                    "description": "When enabled, include the favicon URL of each crawled page."
                  },
                  "timeout": {
                    "type": "number",
                    "format": "float",
                    "default": 150,
                    "description": "Maximum time to wait for the crawl operation to finish, in seconds.",
                    "minimum": 10,
                    "maximum": 150
                  },
                  "include_usage": {
                    "type": "boolean",
                    "default": false,
                    "description": "When enabled, include credit usage details for this request in the response."
                  }
                },
                "required": [
                  "url"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Crawl results returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "base_url": {
                      "type": "string",
                      "description": "Root URL that was crawled."
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "url": {
                            "type": "string",
                            "description": "URL of the crawled page."
                          },
                          "raw_content": {
                            "type": "string",
                            "description": "Cleaned, parsed content of the crawled page in the requested format."
                          },
                          "favicon": {
                            "type": "string",
                            "description": "Favicon URL of the crawled page; present only when favicons were requested."
                          }
                        }
                      },
                      "description": "Pages visited during the crawl, with their extracted content."
                    },
                    "response_time": {
                      "type": "number",
                      "format": "float",
                      "description": "Server-side time taken to complete the request, in seconds."
                    },
                    "usage": {
                      "type": "object",
                      "properties": {
                        "credits": {
                          "type": "integer",
                          "description": "Number of credits consumed by this request."
                        }
                      },
                      "description": "Credit usage for this request; present only when usage reporting was requested."
                    },
                    "request_id": {
                      "type": "string",
                      "description": "Unique identifier of this request, useful for tracing and support."
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Traverse a website starting from a root URL, following links breadth- and depth-first within configurable limits, and return the extracted content of each visited page. Steer which links are followed with natural-language instructions and path/domain include or exclude filters."
      }
    },
    "/tavily/map": {
      "post": {
        "tags": [
          "https://docs.tavily.com/documentation/api-reference/endpoint/map"
        ],
        "summary": "Generate comprehensive site maps using Tavily Map.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "description": "Root URL where the mapping begins.",
                    "example": "docs.tavily.com"
                  },
                  "instructions": {
                    "type": "string",
                    "description": "Natural-language guidance telling the crawler which links to prioritize while mapping the site."
                  },
                  "max_depth": {
                    "type": "integer",
                    "default": 1,
                    "description": "How many link hops away from the root URL the mapping may go.",
                    "minimum": 1,
                    "maximum": 5
                  },
                  "max_breadth": {
                    "type": "integer",
                    "default": 20,
                    "description": "How many links may be followed at each level of the link tree.",
                    "minimum": 1,
                    "maximum": 500
                  },
                  "limit": {
                    "type": "integer",
                    "default": 50,
                    "description": "Total number of links the crawler will process before it stops.",
                    "minimum": 1
                  },
                  "select_paths": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Regex patterns; only URLs whose path matches are mapped."
                  },
                  "select_domains": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Regex patterns; mapping is restricted to matching domains or subdomains."
                  },
                  "exclude_paths": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Regex patterns; URLs whose path matches are skipped."
                  },
                  "exclude_domains": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Regex patterns; matching domains or subdomains are skipped."
                  },
                  "allow_external": {
                    "type": "boolean",
                    "default": true,
                    "description": "When enabled, links pointing to external domains are also kept in the results."
                  },
                  "timeout": {
                    "type": "number",
                    "format": "float",
                    "default": 150,
                    "description": "Maximum time to wait for the map operation to finish, in seconds.",
                    "minimum": 10,
                    "maximum": 150
                  },
                  "include_usage": {
                    "type": "boolean",
                    "default": false,
                    "description": "When enabled, include credit usage details for this request in the response."
                  }
                },
                "required": [
                  "url"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Map results returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "base_url": {
                      "type": "string",
                      "description": "Root URL that was mapped."
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "description": "URLs discovered during the mapping."
                      },
                      "description": "Flat list of URLs discovered while mapping the site."
                    },
                    "response_time": {
                      "type": "number",
                      "format": "float",
                      "description": "Server-side time taken to complete the request, in seconds."
                    },
                    "usage": {
                      "type": "object",
                      "properties": {
                        "credits": {
                          "type": "integer",
                          "description": "Number of credits consumed by this request."
                        }
                      },
                      "description": "Credit usage for this request; present only when usage reporting was requested."
                    },
                    "request_id": {
                      "type": "string",
                      "description": "Unique identifier of this request, useful for tracing and support."
                    }
                  }
                }
              }
            }
          }
        },
        "description": "Discover the link structure of a website starting from a root URL and return the list of reachable URLs, without extracting page content. Useful for mapping a site before deciding what to crawl or extract."
      }
    }
  }
}
