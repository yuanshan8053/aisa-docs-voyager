{
  "openapi": "3.0.0",
  "info": {
    "title": "Tavily API",
    "version": "1.0.0",
    "description": "Unified API documentation for Tavily endpoints including Search, Extract, Crawl, and Map."
  },
  "servers": [
    {
      "url": "https://api.aisa.one/apis/v1"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/tavily/search": {
      "post": {
        "tags": [
          "https://docs.tavily.com/documentation/api-reference/endpoint/search"
        ],
        "summary": "Execute a search query using Tavily Search.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "Natural-language search query to run against the web.",
                    "example": "Who is Leo Messi?"
                  },
                  "search_depth": {
                    "type": "string",
                    "enum": [
                      "advanced",
                      "basic",
                      "fast",
                      "ultra-fast"
                    ],
                    "default": "basic",
                    "description": "Latency vs. relevance tradeoff: lighter modes return faster but shallower results, heavier modes search more thoroughly at higher latency and cost.\n[⚠️Note:各枚举值与延迟/成本的具体对应关系源码未说明，待研发确认。]"
                  },
                  "chunks_per_source": {
                    "type": "integer",
                    "default": 3,
                    "description": "How many of the most relevant text chunks to keep from each matched source.",
                    "minimum": 1,
                    "maximum": 3
                  },
                  "max_results": {
                    "type": "integer",
                    "default": 5,
                    "description": "Upper bound on the number of search results returned.",
                    "minimum": 0,
                    "maximum": 20
                  },
                  "topic": {
                    "type": "string",
                    "enum": [
                      "general",
                      "news",
                      "finance"
                    ],
                    "default": "general",
                    "description": "Search category that biases ranking and freshness: `general` for broad web, `news` for recent journalism, `finance` for financial sources."
                  },
                  "time_range": {
                    "type": "string",
                    "enum": [
                      "day",
                      "week",
                      "month",
                      "year",
                      "d",
                      "w",
                      "m",
                      "y"
                    ],
                    "description": "Restrict results to content published within a recent window relative to now; both full words and single-letter aliases are accepted."
                  },
                  "start_date": {
                    "type": "string",
                    "format": "date",
                    "description": "Keep only results published on or after this date.",
                    "example": "2025-02-09"
                  },
                  "end_date": {
                    "type": "string",
                    "format": "date",
                    "description": "Keep only results published on or before this date.",
                    "example": "2025-12-29"
                  },
                  "include_answer": {
                    "type": "boolean",
                    "default": false,
                    "description": "When enabled, attach a concise LLM-generated answer to the query in the response."
                  },
                  "include_raw_content": {
                    "type": "boolean",
                    "default": false,
                    "description": "When enabled, attach the cleaned, parsed page content of each result rather than just a snippet."
                  },
                  "include_images": {
                    "type": "boolean",
                    "default": false,
                    "description": "When enabled, also run an image search and return matching images."
                  },
                  "include_image_descriptions": {
                    "type": "boolean",
                    "default": false,
                    "description": "When enabled, add a descriptive caption to each returned image; only takes effect when image results are requested."
                  },
                  "include_favicon": {
                    "type": "boolean",
                    "default": false,
                    "description": "When enabled, include the favicon URL of each result's source site."
                  },
                  "include_domains": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Restrict the search to only these domains; results from other sites are dropped.",
                    "maxItems": 300
                  },
                  "exclude_domains": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Drop any results coming from these domains.",
                    "maxItems": 150
                  },
                  "country": {
                    "type": "string",
                    "description": "Boost results originating from the given country; most effective for region-specific queries.",
                    "enum": [
                      "afghanistan",
                      "albania",
                      "algeria",
                      "andorra",
                      "angola",
                      "argentina",
                      "armenia",
                      "australia",
                      "austria",
                      "azerbaijan",
                      "bahamas",
                      "bahrain",
                      "bangladesh",
                      "barbados",
                      "belarus",
                      "belgium",
                      "belize",
                      "benin",
                      "bhutan",
                      "bolivia",
                      "bosnia and herzegovina",
                      "botswana",
                      "brazil",
                      "brunei",
                      "bulgaria",
                      "burkina faso",
                      "burundi",
                      "cambodia",
                      "cameroon",
                      "canada",
                      "cape verde",
                      "central african republic",
                      "chad",
                      "chile",
                      "china",
