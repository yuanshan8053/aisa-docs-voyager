{
  "openapi": "3.0.0",
  "info": {
    "title": "Tavily API",
    "version": "1.0.0",
    "description": "Unified API documentation for Tavily endpoints including Search, Extract, Crawl, and Map."
  },
  "servers": [
    {
      "url": "https://api.aisa.one/apis/v1"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/tavily/search": {
      "post": {
        "tags": [
          "https://docs.tavily.com/documentation/api-reference/endpoint/search"
        ],
        "summary": "执行搜索 POST /tavily/search",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "要在网络上检索的自然语言查询。",
                    "example": "Who is Leo Messi?"
                  },
                  "search_depth": {
                    "type": "string",
                    "enum": [
                      "advanced",
                      "basic",
                      "fast",
                      "ultra-fast"
                    ],
                    "default": "basic",
                    "description": "延迟与相关度的取舍：较轻量的模式返回更快但更浅，较重的模式检索更彻底，但延迟和成本更高。\n[⚠️批注:各枚举值与延迟/成本的具体对应关系源码未说明，待研发确认。]"
                  },
                  "chunks_per_source": {
                    "type": "integer",
                    "default": 3,
                    "description": "每个命中来源保留的最相关文本片段数量。",
                    "minimum": 1,
                    "maximum": 3
                  },
                  "max_results": {
                    "type": "integer",
                    "default": 5,
                    "description": "返回搜索结果数量的上限。",
                    "minimum": 0,
                    "maximum": 20
                  },
                  "topic": {
                    "type": "string",
                    "enum": [
                      "general",
                      "news",
                      "finance"
                    ],
                    "default": "general",
                    "description": "搜索类别，会影响排序与时效偏好：`general` 面向通用网页，`news` 面向时事新闻，`finance` 面向金融来源。"
                  },
                  "time_range": {
                    "type": "string",
                    "enum": [
                      "day",
                      "week",
                      "month",
                      "year",
                      "d",
                      "w",
                      "m",
                      "y"
                    ],
                    "description": "将结果限制在相对当前的近期时间窗内发布的内容；支持完整单词与单字母简写两种写法。"
                  },
                  "start_date": {
                    "type": "string",
                    "format": "date",
                    "description": "仅保留在该日期当天或之后发布的结果。",
                    "example": "2025-02-09"
                  },
                  "end_date": {
                    "type": "string",
                    "format": "date",
                    "description": "仅保留在该日期当天或之前发布的结果。",
                    "example": "2025-12-29"
                  },
                  "include_answer": {
                    "type": "boolean",
                    "default": false,
                    "description": "开启后，响应中附带一段由 LLM 生成的简洁问题答案。"
                  },
                  "include_raw_content": {
                    "type": "boolean",
                    "default": false,
                    "description": "开启后，为每条结果附带清洗解析后的完整页面内容，而不仅是摘要片段。"
                  },
                  "include_images": {
                    "type": "boolean",
                    "default": false,
                    "description": "开启后，额外执行图片搜索并返回匹配的图片。"
                  },
                  "include_image_descriptions": {
                    "type": "boolean",
                    "default": false,
                    "description": "开启后，为每张返回的图片附加描述文字；仅在请求图片结果时生效。"
                  },
                  "include_favicon": {
                    "type": "boolean",
                    "default": false,
                    "description": "开启后，为每条结果附带来源站点的 favicon URL。"
                  },
                  "include_domains": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "将搜索限定在这些域名内，其他站点的结果会被剔除。",
                    "maxItems": 300
                  },
                  "exclude_domains": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "剔除来自这些域名的结果。",
                    "maxItems": 150
                  },
                  "country": {
                    "type": "string",
                    "description": "提升来自指定国家的结果权重，对地域性查询效果最明显。",
                    "enum": [
                      "afghanistan",
                      "albania",
                      "algeria",
                      "andorra",
                      "angola",
                      "argentina",
                      "armenia",
                      "australia",
                      "austria",
                      "azerbaijan",
                      "bahamas",
                      "bahrain",
                      "bangladesh",
