{
  "openapi": "3.0.3",
  "info": {
    "title": "Image Generation via Chat Completions",
    "version": "1.0.0",
    "description": "Wan 2.7 image models (`wan2.7-image`, `wan2.7-image-pro`) are exposed through the standard `POST /v1/chat/completions` endpoint rather than `/v1/images/generations`. Send a chat request with a multimodal `content` array; AIsa returns `choices[].message.content[]` containing one or more `{type: \"image\"}` parts."
  },
  "servers": [
    {
      "url": "https://api.aisa.one/v1"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "AISA API Key"
      }
    }
  },
  "paths": {
    "/chat/completions": {
      "post": {
        "summary": "通过对话补全生成图像 generateImageViaChat",
        "description": "借助标准的对话补全端点,用 Wan 2.7 系列图像模型生成图像。将提示词以带类型的片段放入最后一条用户消息中,可选附参考图以做图生图;生成结果以图像片段形式回填在助手消息里。\n\n**错误码**\n\n| 状态码 | 说明 |\n| --- | --- |\n| `400` | 请求无效。最常见原因是把 `content` 写成了字符串而非片段数组,会返回 `Input should be a valid list: messages[*].content`。 |\n| `401` | AIsa API Key 缺失或无效。 |\n| `429` | 触发限流。 |\n| `500` | 服务内部错误。 |\n| `502` | 上游服务商不可达。 |",
        "operationId": "generateImageViaChat",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "model",
                  "messages"
                ],
                "properties": {
                  "model": {
                    "type": "string",
                    "enum": [
                      "wan2.7-image",
                      "wan2.7-image-pro"
                    ],
                    "description": "本次使用的图像模型。两个变体在画质与价格之间权衡,pro 变体以更高的单图成本换取更高的保真度。"
                  },
                  "messages": {
                    "type": "array",
                    "description": "发送给模型的对话。把图像提示词放进最后一条用户消息;每条消息带有角色,以及一个由带类型片段组成的 content 数组。",
                    "items": {
                      "type": "object",
                      "required": [
                        "role",
                        "content"
                      ],
                      "properties": {
                        "role": {
                          "type": "string",
                          "enum": [
                            "system",
                            "user",
                            "assistant"
                          ],
                          "description": "该消息的作者身份,用于区分系统引导、用户输入与助手既往输出。"
                        },
                        "content": {
                          "type": "array",
                          "description": "构成一条消息的带类型片段。它必须是片段数组而非纯字符串;做图像生成时至少包含一个携带提示词的文本片段,做图生图时再加入图像片段。",
                          "items": {
                            "type": "object",
                            "required": [
                              "type"
                            ],
                            "properties": {
                              "type": {
                                "type": "string",
                                "enum": [
                                  "text",
                                  "image_url"
                                ],
                                "description": "该片段的类别:承载提示词的文本片段,或为图生图提供参考图的图像 URL 片段。"
                              },
                              "text": {
                                "type": "string",
                                "description": "提示词文本,用于文本类型的片段。"
                              },
                              "image_url": {
                                "type": "object",
                                "description": "用于图生图的参考图,在图像 URL 类型片段中提供。",
                                "properties": {
                                  "url": {
                                    "type": "string",
                                    "format": "uri",
                                    "description": "参考图的地址。"
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  },
                  "n": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 4,
                    "default": 4,
                    "description": "单次调用生成的候选图像数量。每张图单独计费,需要省成本时请减少数量。"
                  }
                }
              },
              "examples": {
                "basic": {
                  "summary": "Single-image prompt (n=1)",
                  "value": {
                    "model": "wan2.7-image",
                    "messages": [
                      {
                        "role": "user",
                        "content": [
                          {
                            "type": "text",
                            "text": "A cute red panda, ultra-detailed, cinematic lighting"
                          }
                        ]
                      }
                    ],
                    "n": 1
                  }
                },
                "four_variants": {
                  "summary": "Default 4 candidates for selection",
                  "value": {
                    "model": "wan2.7-image",
                    "messages": [
                      {
                        "role": "user",
                        "content": [
                          {
                            "type": "text",
                            "text": "A futuristic cyberpunk city, neon lights, rainy night, 8k"
                          }
                        ]
                      }
                    ]
                  }
                },
                "pro": {
                  "summary": "Higher-fidelity pro model",
                  "value": {
                    "model": "wan2.7-image-pro",
                    "messages": [
                      {
                        "role": "user",
                        "content": [
                          {
                            "type": "text",
                            "text": "Oil painting of a rolling hillside at sunset, artstation"
                          }
                        ]
                      }
                    ],
                    "n": 1
                  }
                },
                "image_to_image": {
                  "summary": "Image-to-image (reference + prompt)",
                  "value": {
                    "model": "wan2.7-image-pro",
                    "messages": [
                      {
                        "role": "user",
                        "content": [
                          {
                            "type": "image_url",
                            "image_url": {
                              "url": "https://example.com/reference.jpg"
                            }
                          },
                          {
                            "type": "text",
                            "text": "Transform into an oil painting in the style of Van Gogh"
                          }
                        ]
                      }
                    ],
                    "n": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Images generated. Returned as Chat Completion with `message.content[]` image parts.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "example": "chatcmpl-fcc86dfd-9424-9523-b0bd-cdf07383bee2",
                      "description": "本次生成响应的唯一标识。"
                    },
                    "object": {
                      "type": "string",
                      "example": "chat.completion",
                      "description": "载荷的对象类型,沿用对话补全的响应结构。"
                    },
                    "created": {
                      "type": "integer",
                      "example": 1776495713,
                      "description": "该响应的生成时间。"
                    },
                    "model": {
                      "type": "string",
                      "example": "wan2.7-image",
                      "description": "实际处理本次请求的图像模型。"
                    },
                    "choices": {
                      "type": "array",
                      "description": "生成结果,每张图像对应一个条目。",
                      "items": {
                        "type": "object",
                        "properties": {
                          "index": {
                            "type": "integer",
                            "nullable": true,
                            "description": "该结果在 choices 列表中的位置。"
                          },
                          "finish_reason": {
                            "type": "string",
                            "example": "stop",
                            "description": "该结果停止生成的原因。"
                          },
                          "message": {
                            "type": "object",
                            "properties": {
                              "role": {
                                "type": "string",
                                "example": "assistant",
                                "description": "生成消息的作者角色,固定为助手。"
                              },
                              "content": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "required": [
                                    "type"
                                  ],
                                  "properties": {
                                    "type": {
                                      "type": "string",
                                      "enum": [
                                        "image"
                                      ],
                                      "description": "片段类别,标记该片段为生成图像。"
                                    },
                                    "image": {
                                      "type": "string",
                                      "description": "生成的图像本身,依据账号配置以短时有效的 URL 或 base64 数据形式给出。"
                                    }
                                  }
                                },
                                "description": "该消息的片段;在本接口中每个片段包裹一张生成图像。"
                              }
                            },
                            "description": "承载生成图像的助手消息。"
                          }
                        }
                      }
                    },
                    "usage": {
                      "type": "object",
                      "properties": {
                        "prompt_tokens": {
                          "type": "integer",
                          "description": "输入提示词消耗的 token 数。"
                        },
                        "completion_tokens": {
                          "type": "integer",
                          "description": "归于生成输出的 token 数。"
                        },
                        "total_tokens": {
                          "type": "integer",
                          "description": "输入与输出合计的 token 数。"
                        }
                      },
                      "description": "本次请求的 token 计量。"
                    }
                  }
                },
                "example": {
                  "id": "chatcmpl-fcc86dfd-9424-9523-b0bd-cdf07383bee2",
                  "object": "chat.completion",
                  "created": 1776495713,
                  "model": "wan2.7-image",
                  "choices": [
                    {
                      "index": 0,
                      "finish_reason": "stop",
                      "message": {
                        "role": "assistant",
                        "content": [
                          {
                            "type": "image",
                            "image": "https://cdn.aisa.one/images/wan2.7/20260418-abc.png"
                          }
                        ]
                      }
                    }
                  ],
                  "usage": {
                    "prompt_tokens": 104,
                    "completion_tokens": 8,
                    "total_tokens": 112
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request. Most common: `content` passed as a string instead of an array → `\"Input should be a valid list: messages[*].content\"`."
          },
          "401": {
            "description": "Missing or invalid AIsa API key."
          },
          "429": {
            "description": "Rate limit hit."
          },
          "500": {
            "description": "Internal error."
          },
          "502": {
            "description": "Upstream provider unreachable."
          }
        }
      }
    }
  }
}
