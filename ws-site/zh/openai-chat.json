{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenAI Chat API",
    "version": "1.0.0",
    "description": "OpenAI Chat Completion API including Image Analysis, Streaming, Function Calling, and Logprobs."
  },
  "servers": [
    {
      "url": "https://api.aisa.one/v1"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API Key"
      }
    }
  },
  "paths": {
    "/chat/completions": {
      "post": {
        "summary": "创建对话补全 createChatCompletion",
        "description": "为一段对话生成模型回复。除纯文本外,支持在消息内容中传入图像、逐 token 流式输出、函数调用,以及逐 token 的对数概率 —— 让单个接口覆盖对话、多模态分析与工具编排。",
        "operationId": "createChatCompletion",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "model": {
                    "type": "string",
                    "example": "gpt-4.1",
                    "description": "本次补全所用模型的标识。它决定调用的能力档位与计费;可选标识取自模型目录,而非本字段自身。"
                  },
                  "messages": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "role": {
                          "type": "string",
                          "example": "user",
                          "description": "本轮的说话方 —— 通常是 system(指令)、user 或 assistant(模型先前的回复)。它告诉模型该如何权衡这一轮。"
                        },
                        "content": {
                          "description": "本轮的内容载荷。纯文本消息传字符串;若要图文混排做多模态分析,则传一个带类型的分块数组。",
                          "oneOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "type": {
                                    "type": "string",
                                    "description": "在多模态内容数组中标记该分块的种类,使每块被分别解读为文本或图像引用。"
                                  },
                                  "text": {
                                    "type": "string",
                                    "description": "文本类型分块的文字内容。"
                                  },
                                  "image_url": {
                                    "type": "string",
                                    "description": "图像类型分块的图片地址;模型会拉取它并与文本分块一同分析。"
                                  }
                                }
                              }
                            }
                          ]
                        }
                      }
                    },
                    "description": "至今为止的对话,按轮次有序排列。模型按顺序读取并从最后一轮续写,因此顺序本身承载了对话状态。"
                  },
                  "stream": {
                    "type": "boolean",
                    "example": false,
                    "description": "开启后,回复以增量分块的流式形式陆续返回,而非一次性整段返回 —— 适合边生成边展示。关闭则在单次响应中返回完整回复。"
                  },
                  "logprobs": {
                    "type": "boolean",
                    "description": "开启后,响应附带每个返回 token 的对数概率,可借此衡量模型在每一步的置信度。"
                  },
                  "top_logprobs": {
                    "type": "integer",
                    "description": "每个位置上报多少个最可能的备选 token,并各带其对数概率。需先开启 logprobs。"
                  },
                  "functions": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string",
                          "description": "函数名。模型请求调用时以此指代,你的代码派发时以此匹配。"
                        },
                        "description": {
                          "type": "string",
                          "description": "函数的功能说明,写给模型看。清晰的描述是模型判断「何时该用这个函数」的主要依据。"
                        },
                        "parameters": {
                          "type": "object",
                          "properties": {},
                          "description": "描述函数入参的 JSON Schema。模型请求调用时会据此生成符合该结构的参数值。"
                        }
                      }
                    },
                    "description": "声明模型可以调用的函数。模型自身从不执行它们,而是返回一个指明函数名与入参的结构化请求,再由你的代码去执行。"
                  },
                  "function_call": {
                    "oneOf": [
                      {
                        "type": "string",
                        "example": "auto"
                      },
                      {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string",
                            "description": "以对象形式强制调用时,模型必须调用的函数名。"
                          }
                        }
                      }
                    ],
                    "description": "控制函数调用行为:传 `auto` 这类字符串模式让模型自行决定是否调用,或传一个指名某函数的对象以强制调用该函数。"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful completion"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Examples"
    }
  ]
}
