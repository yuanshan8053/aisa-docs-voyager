  "paths": {
    "/scholar/search/mixed": {
      "post": {
        "summary": "Smart search combining web and academic results",
        "description": "Perform intelligent search that combines web and academic results",
        "operationId": "searchSmart",
        "tags": [
          "Search",
          "Smart"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "Search query for scholarly materials",
            "schema": {
              "type": "string",
              "example": "machine learning"
            },
            "x-doc": {
              "desc_en": "The search terms to look up.",
              "title_zh": "要检索的查询词。",
              "source": "ai",
              "src_hash": "sha256:db1e3b03702b",
              "doc_version": "2.0.0"
            }
          },
          {
            "name": "max_num_results",
            "in": "query",
            "description": "Maximum number of search results to return, up to 100",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 10
            },
            "x-doc": {
              "desc_en": "Caps how many results come back.",
              "title_zh": "限制返回结果的数量上限。",
              "source": "ai",
              "src_hash": "sha256:85de30d1bbef",
              "doc_version": "2.0.0"
            }
          },
          {
            "name": "as_ylo",
            "in": "query",
            "description": "Year of publication lower bound",
            "schema": {
              "type": "integer",
              "nullable": true,
              "minimum": 1900,
              "maximum": 2030
            },
            "x-doc": {
              "desc_en": "Earliest publication year to include; results published before it are excluded.",
              "title_zh": "纳入结果的最早出版年份，早于该年份的结果会被排除。",
              "source": "ai",
              "src_hash": "sha256:cd5a9e67343e",
              "doc_version": "2.0.0"
            }
          },
          {
            "name": "as_yhi",
            "in": "query",
            "description": "Year of publication upper bound",
            "schema": {
              "type": "integer",
              "nullable": true,
              "minimum": 1900,
              "maximum": 2030
            },
            "x-doc": {
              "desc_en": "Latest publication year to include; results published after it are excluded.",
              "title_zh": "纳入结果的最晚出版年份，晚于该年份的结果会被排除。",
              "source": "ai",
              "src_hash": "sha256:6533bb0e02b6",
              "doc_version": "2.0.0"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful search response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SmartSearchResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "x-doc": {
          "heading_zh": "智能混合搜索 searchSmart",
          "desc_en": "Run a single query that blends general web results with academic-paper results, returning a unified ranked list plus a `search_id` you can later pass to `explainSearch` for an AI explanation.",
          "description_zh": "用一次查询同时检索网页与学术论文，返回融合排序后的结果列表，并附带可交给 explainSearch 生成解读的检索标识。",
          "source": "ai",
          "src_hash": "sha256:934cbc7780bb",
          "doc_version": "2.0.0"
        }
      }
    },
