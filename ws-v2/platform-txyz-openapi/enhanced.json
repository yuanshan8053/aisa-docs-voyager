              "source": "ai",
              "src_hash": "sha256:03e95ad4ecd4",
              "doc_version": "2.0.0"
            }
          }
        }
      },
      "SmartSearchResponse": {
        "type": "object",
        "required": [
          "id",
          "results"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the search request",
            "x-doc": {
