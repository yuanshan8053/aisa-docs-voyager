            "x-doc": {
              "desc_en": "Title of the paper.",
              "title_zh": "论文标题。",
              "source": "ai",
              "src_hash": "sha256:1c39c391e87d",
              "doc_version": "2.0.0"
            }
          },
          "link": {
            "type": "string",
            "format": "uri",
