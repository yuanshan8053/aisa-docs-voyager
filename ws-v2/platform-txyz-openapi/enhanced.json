              "doc_version": "2.0.0"
            }
          },
          "number_of_citations": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of citations the paper has received",
            "x-doc": {
              "desc_en": "How many times the paper has been cited.",
              "title_zh": "论文被引用的次数。",
              "source": "ai",
              "src_hash": "sha256:13b76786431f",
              "doc_version": "2.0.0"
            }
          },
          "year": {
            "type": "integer",
            "description": "Publication year",
            "minimum": 1900,
            "maximum": 2030,
            "x-doc": {
              "desc_en": "Year the paper was published.",
              "title_zh": "论文的出版年份。",
              "source": "ai",
              "src_hash": "sha256:bc7b81fc9b13",
              "doc_version": "2.0.0"
