    "schemas": {
      "ScholarSearchResponse": {
        "type": "object",
        "required": [
          "id",
          "results"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the search request",
            "x-doc": {
              "desc_en": "Identifier of this search request; pass it to `explainSearch` to get an explanation of these results.",
              "title_zh": "本次搜索请求的标识，可传给 explainSearch 以解读这批结果。",
              "source": "ai",
              "src_hash": "sha256:bbee6f2a0201",
              "doc_version": "2.0.0"
            }
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ScholarResult"
            },
            "description": "List of academic paper results",
            "x-doc": {
              "desc_en": "The academic paper result list.",
              "title_zh": "学术论文结果列表。",
              "source": "ai",
              "src_hash": "sha256:d3198cbb9bad",
              "doc_version": "2.0.0"
            }
          }
        }
      },
      "ScholarResult": {
        "type": "object",
        "required": [
          "title",
          "link",
          "snippet",
          "authors",
          "number_of_citations"
        ],
        "properties": {
          "title": {
            "type": "string",
