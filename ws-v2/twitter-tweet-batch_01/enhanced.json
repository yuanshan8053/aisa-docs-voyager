{
  "openapi": "3.0.3",
  "info": {
    "title": "Twitter API Aggregated",
    "version": "1.0.0",
    "description": "Aggregated API documentation for Twitter data endpoints."
  },
  "servers": [
    {
      "url": "https://api.aisa.one/apis/v1"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Tweet": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "x-doc": {
              "desc_en": "Object type tag identifying the entry as a tweet.",
              "title_zh": "对象类型标记，标识该条目为推文。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "id": {
            "type": "string",
            "x-doc": {
              "desc_en": "Unique identifier of the tweet.",
              "title_zh": "推文的唯一标识。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "url": {
            "type": "string",
            "x-doc": {
              "desc_en": "Web link to the tweet on X/Twitter.",
              "title_zh": "推文在 X/Twitter 上的网页链接。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "text": {
            "type": "string",
            "x-doc": {
              "desc_en": "Full text content of the tweet.",
              "title_zh": "推文的完整正文内容。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "source": {
            "type": "string",
            "x-doc": {
              "desc_en": "Name of the client application used to post the tweet.",
              "title_zh": "发布该推文所用的客户端应用名称。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "retweetCount": {
            "type": "integer",
            "x-doc": {
              "desc_en": "Number of times the tweet has been retweeted.",
              "title_zh": "推文被转发的次数。",
              "source": "ai",
              "src_hash": "sha256:644595857f56",
              "doc_version": "2.0.0"
            }
          },
          "replyCount": {
            "type": "integer",
            "x-doc": {
              "desc_en": "Number of replies to the tweet.",
              "title_zh": "推文收到的回复数。",
              "source": "ai",
              "src_hash": "sha256:644595857f56",
              "doc_version": "2.0.0"
            }
          },
          "likeCount": {
            "type": "integer",
            "x-doc": {
              "desc_en": "Number of likes on the tweet.",
              "title_zh": "推文获得的点赞数。",
              "source": "ai",
              "src_hash": "sha256:644595857f56",
              "doc_version": "2.0.0"
            }
          },
          "quoteCount": {
            "type": "integer",
            "x-doc": {
              "desc_en": "Number of quote tweets referencing this tweet.",
              "title_zh": "引用该推文的引用推文数。",
              "source": "ai",
              "src_hash": "sha256:644595857f56",
              "doc_version": "2.0.0"
            }
          },
          "viewCount": {
            "type": "integer",
            "x-doc": {
              "desc_en": "Number of times the tweet has been viewed.",
              "title_zh": "推文的浏览次数。",
              "source": "ai",
              "src_hash": "sha256:644595857f56",
              "doc_version": "2.0.0"
            }
          },
          "createdAt": {
            "type": "string",
            "x-doc": {
              "desc_en": "Timestamp when the tweet was created.",
              "title_zh": "推文的创建时间。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "lang": {
            "type": "string",
            "x-doc": {
              "desc_en": "Detected language of the tweet text, as a language code.",
              "title_zh": "推文正文被识别出的语言，以语言代码表示。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "bookmarkCount": {
            "type": "integer",
            "x-doc": {
              "desc_en": "Number of times the tweet has been bookmarked.",
              "title_zh": "推文被收藏的次数。",
              "source": "ai",
              "src_hash": "sha256:644595857f56",
              "doc_version": "2.0.0"
            }
          },
          "isReply": {
            "type": "boolean",
            "x-doc": {
              "desc_en": "Whether the tweet is a reply to another tweet.",
              "title_zh": "该推文是否为对另一条推文的回复。",
              "source": "ai",
              "src_hash": "sha256:8e2bc3398639",
              "doc_version": "2.0.0"
            }
          },
          "inReplyToId": {
            "type": "string",
            "x-doc": {
              "desc_en": "Identifier of the tweet this one directly replies to; present only when isReply is true.",
              "title_zh": "该推文直接回复的目标推文标识；仅当 isReply 为真时存在。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "conversationId": {
            "type": "string",
            "x-doc": {
              "desc_en": "Identifier of the root tweet that started the conversation thread this tweet belongs to.",
              "title_zh": "该推文所属对话线程的起始推文标识。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "displayTextRange": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "x-doc": {
              "desc_en": "Start and end character offsets marking the displayable portion of the tweet text.",
              "title_zh": "标记推文正文中可显示部分的起止字符位置。",
              "source": "ai",
              "src_hash": "sha256:935373eda591",
              "doc_version": "2.0.0"
            }
          },
          "inReplyToUserId": {
            "type": "string",
            "x-doc": {
              "desc_en": "Identifier of the user being replied to.",
              "title_zh": "被回复用户的标识。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "inReplyToUsername": {
            "type": "string",
            "x-doc": {
              "desc_en": "Username of the user being replied to.",
              "title_zh": "被回复用户的用户名。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "author": {
            "$ref": "#/components/schemas/User",
            "x-doc": {
              "desc_en": "Profile of the user who posted the tweet.",
              "title_zh": "发布该推文的用户资料。",
              "source": "ai",
              "src_hash": "sha256:8d574c2d1bfd",
              "doc_version": "2.0.0"
            }
          },
          "entities": {
            "type": "object",
            "properties": {
              "hashtags": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "indices": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      },
                      "x-doc": {
                        "desc_en": "Start and end character offsets of the hashtag within the tweet text.",
                        "title_zh": "该话题标签在推文正文中的起止字符位置。",
                        "source": "ai",
                        "src_hash": "sha256:935373eda591",
                        "doc_version": "2.0.0"
                      }
                    },
                    "text": {
                      "type": "string",
                      "x-doc": {
                        "desc_en": "The hashtag word, without the leading # sign.",
                        "title_zh": "话题标签的文字，不含开头的 # 号。",
                        "source": "ai",
                        "src_hash": "sha256:38a346cadbd3",
                        "doc_version": "2.0.0"
                      }
                    }
                  }
                },
                "x-doc": {
                  "desc_en": "Hashtags found in the tweet text.",
                  "title_zh": "推文正文中出现的话题标签。",
                  "source": "ai",
                  "src_hash": "sha256:e9ae57349c27",
                  "doc_version": "2.0.0"
                }
              },
              "urls": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "display_url": {
                      "type": "string",
                      "x-doc": {
                        "desc_en": "Shortened, human-readable form of the link as displayed in the tweet.",
                        "title_zh": "推文中显示的链接的短化、易读形式。",
                        "source": "ai",
                        "src_hash": "sha256:38a346cadbd3",
                        "doc_version": "2.0.0"
                      }
                    },
                    "expanded_url": {
                      "type": "string",
                      "x-doc": {
                        "desc_en": "Full destination URL the displayed link resolves to.",
                        "title_zh": "显示链接最终指向的完整目标地址。",
                        "source": "ai",
                        "src_hash": "sha256:38a346cadbd3",
                        "doc_version": "2.0.0"
                      }
                    },
                    "indices": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      },
                      "x-doc": {
                        "desc_en": "Start and end character offsets of the link within the tweet text.",
                        "title_zh": "该链接在推文正文中的起止字符位置。",
                        "source": "ai",
                        "src_hash": "sha256:935373eda591",
                        "doc_version": "2.0.0"
                      }
                    },
                    "url": {
                      "type": "string",
                      "x-doc": {
                        "desc_en": "The t.co shortened URL as it literally appears in the tweet text.",
                        "title_zh": "推文正文中实际出现的 t.co 短链接。",
                        "source": "ai",
                        "src_hash": "sha256:38a346cadbd3",
                        "doc_version": "2.0.0"
                      }
                    }
                  }
                },
                "x-doc": {
                  "desc_en": "Links found in the tweet text.",
                  "title_zh": "推文正文中出现的链接。",
                  "source": "ai",
                  "src_hash": "sha256:49ba4ea71b4a",
                  "doc_version": "2.0.0"
                }
              },
              "user_mentions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id_str": {
                      "type": "string",
                      "x-doc": {
                        "desc_en": "Identifier of the mentioned user.",
                        "title_zh": "被提及用户的标识。",
                        "source": "ai",
                        "src_hash": "sha256:38a346cadbd3",
                        "doc_version": "2.0.0"
                      }
                    },
                    "name": {
                      "type": "string",
                      "x-doc": {
                        "desc_en": "Display name of the mentioned user.",
                        "title_zh": "被提及用户的昵称。",
                        "source": "ai",
                        "src_hash": "sha256:38a346cadbd3",
                        "doc_version": "2.0.0"
                      }
                    },
                    "screen_name": {
                      "type": "string",
                      "x-doc": {
                        "desc_en": "@handle of the mentioned user.",
                        "title_zh": "被提及用户的 @ 用户名。",
                        "source": "ai",
                        "src_hash": "sha256:38a346cadbd3",
                        "doc_version": "2.0.0"
                      }
                    }
                  }
                },
                "x-doc": {
                  "desc_en": "Users mentioned in the tweet text.",
                  "title_zh": "推文正文中提及的用户。",
                  "source": "ai",
                  "src_hash": "sha256:cff5d32335f0",
                  "doc_version": "2.0.0"
                }
              }
            },
            "x-doc": {
              "desc_en": "Structured entities parsed from the tweet text, such as hashtags, links, and user mentions.",
              "title_zh": "从推文正文解析出的结构化实体，如话题标签、链接与用户提及。",
              "source": "ai",
              "src_hash": "sha256:6c668b717f8a",
              "doc_version": "2.0.0"
            }
          },
          "quoted_tweet": {
            "type": "string",
            "x-doc": {
              "desc_en": "The tweet quoted by this tweet, when it is a quote tweet.\n[⚠️Note:源码将该字段声明为 string 类型，但其承载的具体内容（如完整推文对象或推文 ID）未声明，待研发确认。]",
              "title_zh": "当该推文为引用推文时，其所引用的推文。\n[⚠️批注:源码将该字段声明为 string 类型，但其承载的具体内容（如完整推文对象或推文 ID）未声明，待研发确认。]",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "retweeted_tweet": {
            "type": "string",
            "x-doc": {
              "desc_en": "The original tweet this tweet retweets, when it is a retweet.\n[⚠️Note:源码将该字段声明为 string 类型，但其承载的具体内容（如完整推文对象或推文 ID）未声明，待研发确认。]",
              "title_zh": "当该推文为转发时，其所转发的原推文。\n[⚠️批注:源码将该字段声明为 string 类型，但其承载的具体内容（如完整推文对象或推文 ID）未声明，待研发确认。]",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "isLimitedReply": {
            "type": "boolean",
            "x-doc": {
              "desc_en": "Whether replies to this tweet are restricted by the author's reply settings.",
              "title_zh": "该推文的回复是否受作者的回复权限设置限制。",
              "source": "ai",
              "src_hash": "sha256:8e2bc3398639",
              "doc_version": "2.0.0"
            }
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "x-doc": {
              "desc_en": "Object type tag identifying the entry as a user.",
              "title_zh": "对象类型标记，标识该条目为用户。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "userName": {
            "type": "string",
            "x-doc": {
              "desc_en": "The user's @handle, unique across X/Twitter and used in profile URLs.",
              "title_zh": "用户的 @ 用户名，在 X/Twitter 上唯一，用于资料页地址。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "url": {
            "type": "string",
            "x-doc": {
              "desc_en": "Web link to the user's profile page.",
              "title_zh": "用户资料页的网页链接。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "id": {
            "type": "string",
            "x-doc": {
              "desc_en": "Unique identifier of the user.",
              "title_zh": "用户的唯一标识。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "name": {
            "type": "string",
            "x-doc": {
              "desc_en": "The user's display name shown on the profile.",
              "title_zh": "用户在资料页展示的昵称。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "isBlueVerified": {
            "type": "boolean",
            "x-doc": {
              "desc_en": "Whether the user holds a paid X (Twitter) Blue verification.",
              "title_zh": "用户是否拥有付费的 X（Twitter）Blue 认证。",
              "source": "ai",
              "src_hash": "sha256:8e2bc3398639",
              "doc_version": "2.0.0"
            }
          },
          "verifiedType": {
            "type": "string",
            "x-doc": {
              "desc_en": "The user's verification category, such as a business or government account.",
              "title_zh": "用户的认证类别，如企业或政府账号。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "profilePicture": {
            "type": "string",
            "x-doc": {
              "desc_en": "Web link to the user's avatar image.",
              "title_zh": "用户头像图片的网页链接。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "coverPicture": {
            "type": "string",
            "x-doc": {
              "desc_en": "Web link to the user's profile banner image.",
              "title_zh": "用户资料页横幅图片的网页链接。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "description": {
            "type": "string",
            "x-doc": {
              "desc_en": "The user's profile bio text.",
              "title_zh": "用户资料页的个人简介文字。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "location": {
            "type": "string",
            "x-doc": {
              "desc_en": "Free-text location the user lists on their profile.",
              "title_zh": "用户在资料页填写的所在地（自由文本）。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "followers": {
            "type": "integer",
            "x-doc": {
              "desc_en": "Number of accounts following the user.",
              "title_zh": "关注该用户的账号数。",
              "source": "ai",
              "src_hash": "sha256:644595857f56",
              "doc_version": "2.0.0"
            }
          },
          "following": {
            "type": "integer",
            "x-doc": {
              "desc_en": "Number of accounts the user follows.",
              "title_zh": "该用户关注的账号数。",
              "source": "ai",
              "src_hash": "sha256:644595857f56",
              "doc_version": "2.0.0"
            }
          },
          "canDm": {
            "type": "boolean",
            "x-doc": {
              "desc_en": "Whether the user currently accepts direct messages from the requester.",
              "title_zh": "该用户当前是否接受请求方的私信。",
              "source": "ai",
              "src_hash": "sha256:8e2bc3398639",
              "doc_version": "2.0.0"
            }
          },
          "createdAt": {
            "type": "string",
            "x-doc": {
              "desc_en": "Timestamp when the user's account was created.",
              "title_zh": "该用户账号的创建时间。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "favouritesCount": {
            "type": "integer",
            "x-doc": {
              "desc_en": "Number of tweets the user has liked.",
              "title_zh": "该用户点赞过的推文数。",
              "source": "ai",
              "src_hash": "sha256:644595857f56",
              "doc_version": "2.0.0"
            }
          },
          "hasCustomTimelines": {
            "type": "boolean",
            "x-doc": {
              "desc_en": "Whether the user has created custom timelines.",
              "title_zh": "该用户是否创建过自定义时间线。",
              "source": "ai",
              "src_hash": "sha256:8e2bc3398639",
              "doc_version": "2.0.0"
            }
          },
          "isTranslator": {
            "type": "boolean",
            "x-doc": {
              "desc_en": "Whether the user participates in the Twitter translation program.",
              "title_zh": "该用户是否参与 Twitter 翻译计划。",
              "source": "ai",
              "src_hash": "sha256:8e2bc3398639",
              "doc_version": "2.0.0"
            }
          },
          "mediaCount": {
            "type": "integer",
            "x-doc": {
              "desc_en": "Number of media items the user has posted.",
              "title_zh": "该用户发布过的媒体条目数。",
              "source": "ai",
              "src_hash": "sha256:644595857f56",
              "doc_version": "2.0.0"
            }
          },
          "statusesCount": {
            "type": "integer",
            "x-doc": {
              "desc_en": "Total number of tweets the user has posted.",
              "title_zh": "该用户发布过的推文总数。",
              "source": "ai",
              "src_hash": "sha256:644595857f56",
              "doc_version": "2.0.0"
            }
          },
          "withheldInCountries": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "x-doc": {
              "desc_en": "Country codes where the user's account is withheld for legal reasons.",
              "title_zh": "因法律原因屏蔽该用户账号的国家／地区代码列表。",
              "source": "ai",
              "src_hash": "sha256:cb839f650391",
              "doc_version": "2.0.0"
            }
          },
          "possiblySensitive": {
            "type": "boolean",
            "x-doc": {
              "desc_en": "Whether the user's posts are flagged as potentially sensitive.",
              "title_zh": "该用户的内容是否被标记为可能含敏感信息。",
              "source": "ai",
              "src_hash": "sha256:8e2bc3398639",
              "doc_version": "2.0.0"
            }
          },
          "pinnedTweetIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "x-doc": {
              "desc_en": "Identifiers of tweets the user has pinned to the top of their profile.",
              "title_zh": "该用户置顶在资料页顶部的推文标识列表。",
              "source": "ai",
              "src_hash": "sha256:cb839f650391",
              "doc_version": "2.0.0"
            }
