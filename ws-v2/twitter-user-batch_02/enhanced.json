                        "source": "ai",
                        "src_hash": "sha256:38a346cadbd3",
                        "doc_version": "2.0.0"
                      }
                    },
                    "expanded_url": {
                      "type": "string",
                      "x-doc": {
                        "desc_en": "Full destination URL the displayed link resolves to.",
                        "title_zh": "显示链接最终指向的完整目标地址。",
                        "source": "ai",
                        "src_hash": "sha256:38a346cadbd3",
                        "doc_version": "2.0.0"
                      }
                    },
                    "indices": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      },
                      "x-doc": {
                        "desc_en": "Start and end character offsets of the link within the tweet text.",
                        "title_zh": "该链接在推文正文中的起止字符位置。",
                        "source": "ai",
                        "src_hash": "sha256:935373eda591",
                        "doc_version": "2.0.0"
                      }
                    },
                    "url": {
                      "type": "string",
                      "x-doc": {
                        "desc_en": "The t.co shortened URL as it literally appears in the tweet text.",
                        "title_zh": "推文正文中实际出现的 t.co 短链接。",
                        "source": "ai",
                        "src_hash": "sha256:38a346cadbd3",
                        "doc_version": "2.0.0"
                      }
                    }
                  }
                },
                "x-doc": {
                  "desc_en": "Links found in the tweet text.",
                  "title_zh": "推文正文中出现的链接。",
