          "coverPicture": {
            "type": "string",
            "x-doc": {
              "desc_en": "Web link to the follower's profile banner image.",
              "title_zh": "关注者资料页横幅图片的网页链接。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "description": {
            "type": "string",
            "x-doc": {
              "desc_en": "The follower's profile bio text.",
              "title_zh": "关注者资料页的个人简介文字。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "location": {
            "type": "string",
            "x-doc": {
              "desc_en": "Free-text location the follower lists on their profile.",
              "title_zh": "关注者在资料页填写的所在地（自由文本）。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "followers": {
            "type": "integer",
            "x-doc": {
              "desc_en": "Number of accounts following the follower.",
              "title_zh": "关注该关注者的账号数。",
              "source": "ai",
              "src_hash": "sha256:644595857f56",
              "doc_version": "2.0.0"
            }
          },
          "following": {
            "type": "integer",
            "x-doc": {
              "desc_en": "Number of accounts the follower follows.",
              "title_zh": "该关注者关注的账号数。",
              "source": "ai",
              "src_hash": "sha256:644595857f56",
              "doc_version": "2.0.0"
            }
          },
          "canDm": {
            "type": "boolean",
            "x-doc": {
              "desc_en": "Whether the follower currently accepts direct messages from the requester.",
              "title_zh": "该关注者当前是否接受请求方的私信。",
              "source": "ai",
              "src_hash": "sha256:8e2bc3398639",
              "doc_version": "2.0.0"
            }
          },
          "createdAt": {
            "type": "string",
            "x-doc": {
              "desc_en": "Timestamp when the follower's account was created.",
              "title_zh": "该关注者账号的创建时间。",
