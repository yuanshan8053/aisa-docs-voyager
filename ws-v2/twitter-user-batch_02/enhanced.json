  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/twitter/user/followings": {
      "get": {
        "tags": [
          "https://docs.twitterapi.io/api-reference/endpoint/get_user_followings"
        ],
        "summary": "Get User Followings",
        "description": "Get user followings. Each page returns exactly 200 followings. Use cursor for pagination.",
        "parameters": [
          {
            "name": "userName",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Screen name of the user.",
            "x-doc": {
              "desc_en": "Screen name (@handle, without the @) of the user whose followings you want.",
              "title_zh": "要查询其关注列表的用户名（@ 后的部分，不含 @）。",
              "source": "ai",
              "src_hash": "sha256:7a5062fa7aa1",
              "doc_version": "2.0.0"
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The cursor to paginate through the results. First page is empty.",
            "x-doc": {
              "desc_en": "Pagination cursor from the previous response's next_cursor; leave empty to start from the first page.",
              "title_zh": "翻页游标，取自上一次响应的 next_cursor；首页请求留空即可。",
              "source": "ai",
              "src_hash": "sha256:46a9e67e16e5",
              "doc_version": "2.0.0"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 200,
              "minimum": 20,
              "maximum": 200
            },
            "description": "The number of followings to return per page.",
            "x-doc": {
              "desc_en": "How many followings to return per page.",
              "title_zh": "每页返回的关注账号数量。",
              "source": "ai",
              "src_hash": "sha256:a5fcb2591940",
              "doc_version": "2.0.0"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserFollowingsResponse"
                }
              }
            }
          }
        },
        "x-doc": {
          "heading_zh": "获取用户关注列表 GET /twitter/user/followings",
          "desc_en": "List the accounts a given user follows, identified by screen name, with cursor pagination and a configurable page size.",
          "description_zh": "按用户名获取某个用户所关注的账号列表，支持游标翻页与可配置的每页数量。",
          "source": "ai",
          "src_hash": "sha256:e62a7039033b",
          "doc_version": "2.0.0"
        }
      }
    },
    "/twitter/user/mentions": {
      "get": {
        "tags": [
          "https://docs.twitterapi.io/api-reference/endpoint/get_user_mention"
        ],
        "summary": "Get User Mentions",
        "description": "Get tweet mentions by user screen name. Each page returns exactly 20 mentions.",
        "parameters": [
          {
            "name": "userName",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The user screen name to get mentions for.",
            "x-doc": {
              "desc_en": "Screen name (@handle, without the @) of the user whose mentions you want.",
              "title_zh": "要查询其被提及推文的用户名（@ 后的部分，不含 @）。",
              "source": "ai",
              "src_hash": "sha256:b325e1862f2d",
              "doc_version": "2.0.0"
            }
          },
          {
            "name": "sinceTime",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "On or after a specified unix timestamp in seconds.",
            "x-doc": {
              "desc_en": "Only return mentions posted at or after this Unix timestamp in seconds.",
              "title_zh": "仅返回在该 Unix 时间戳（秒）当时或之后发布的提及推文。",
              "source": "ai",
              "src_hash": "sha256:6094d85ae3b4",
              "doc_version": "2.0.0"
            }
          },
          {
            "name": "untilTime",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Before a specified unix timestamp in seconds.",
            "x-doc": {
              "desc_en": "Only return mentions posted before this Unix timestamp in seconds.",
              "title_zh": "仅返回在该 Unix 时间戳（秒）之前发布的提及推文。",
              "source": "ai",
              "src_hash": "sha256:610d8d09a056",
              "doc_version": "2.0.0"
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The cursor to paginate through the results. First page is empty.",
            "x-doc": {
              "desc_en": "Pagination cursor from the previous response's next_cursor; leave empty to start from the first page.",
              "title_zh": "翻页游标，取自上一次响应的 next_cursor；首页请求留空即可。",
              "source": "ai",
              "src_hash": "sha256:46a9e67e16e5",
              "doc_version": "2.0.0"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserMentionsResponse"
                }
              }
            }
          }
        },
        "x-doc": {
          "heading_zh": "获取提及用户的推文 GET /twitter/user/mentions",
          "desc_en": "List tweets that mention a given user by screen name, in reverse-chronological order, optionally bounded by a time window and paginated with the cursor.",
          "description_zh": "按用户名获取提及该用户的推文，按时间倒序排列，可选用时间窗口限定范围并通过游标翻页。",
          "source": "ai",
          "src_hash": "sha256:6869577b3f3d",
          "doc_version": "2.0.0"
        }
      }
    },
    "/twitter/user/check_follow_relationship": {
      "get": {
        "tags": [
          "https://docs.twitterapi.io/api-reference/endpoint/check_follow_relationship"
        ],
        "summary": "Check Follow Relationship",
        "description": "Check if the user is following/followed by the target user.",
        "parameters": [
          {
            "name": "source_user_name",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Screen name of the source user.",
            "x-doc": {
              "desc_en": "Screen name of the source user whose follow direction is being checked.",
              "title_zh": "作为关注关系起点被检查的来源用户名。",
              "source": "ai",
              "src_hash": "sha256:dfc9de870b7d",
              "doc_version": "2.0.0"
            }
          },
          {
            "name": "target_user_name",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Screen name of the target user.",
            "x-doc": {
              "desc_en": "Screen name of the target user the relationship is checked against.",
              "title_zh": "作为关注关系对照对象的目标用户名。",
              "source": "ai",
              "src_hash": "sha256:88382508d91a",
              "doc_version": "2.0.0"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FollowRelationshipResponse"
                }
              }
            }
          }
        },
        "x-doc": {
          "heading_zh": "查询关注关系 GET /twitter/user/check_follow_relationship",
          "desc_en": "Check the directional follow relationship between a source user and a target user: whether the source follows the target and whether the target follows the source back.",
          "description_zh": "查询来源用户与目标用户之间的关注关系方向：来源用户是否关注目标用户，以及目标用户是否回关来源用户。",
          "source": "ai",
          "src_hash": "sha256:5c858d1fd01c",
          "doc_version": "2.0.0"
        }
      }
    },
    "/twitter/user/search": {
      "get": {
        "tags": [
          "https://docs.twitterapi.io/api-reference/endpoint/search_user"
        ],
        "summary": "Search User by Keyword",
        "description": "Search user by keyword.",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The keyword to search.",
            "x-doc": {
              "desc_en": "Keyword to match against user profiles when searching.",
              "title_zh": "用于匹配用户资料的搜索关键词。",
              "source": "ai",
              "src_hash": "sha256:f257a4ccf253",
              "doc_version": "2.0.0"
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The cursor to paginate through the results. First page is empty.",
            "x-doc": {
              "desc_en": "Pagination cursor from the previous response's next_cursor; leave empty to start from the first page.",
              "title_zh": "翻页游标，取自上一次响应的 next_cursor；首页请求留空即可。",
              "source": "ai",
              "src_hash": "sha256:46a9e67e16e5",
              "doc_version": "2.0.0"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchUserResponse"
                }
              }
            }
          }
        },
        "x-doc": {
          "heading_zh": "按关键词搜索用户 GET /twitter/user/search",
          "desc_en": "Search for users whose profile matches a keyword, paginated with the cursor.",
          "description_zh": "按关键词搜索资料匹配的用户，并通过游标翻页。",
          "source": "ai",
          "src_hash": "sha256:6411ec79ddf1",
          "doc_version": "2.0.0"
        }
      }
    },
    "/twitter/user/verifiedFollowers": {
      "get": {
        "tags": [
          "https://docs.twitterapi.io/api-reference/endpoint/get_user_verified_followers"
        ],
        "summary": "Get User Verified Followers",
        "description": "Get user verified followers in reverse chronological order.",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User ID of the user.",
            "x-doc": {
              "desc_en": "Identifier of the user whose verified followers you want.",
              "title_zh": "要查询其认证关注者的用户标识。",
              "source": "ai",
              "src_hash": "sha256:a1e9bef4ed30",
              "doc_version": "2.0.0"
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The cursor to paginate through the results. First page is empty.",
            "x-doc": {
              "desc_en": "Pagination cursor from the previous response's next_cursor; leave empty to start from the first page.",
              "title_zh": "翻页游标，取自上一次响应的 next_cursor；首页请求留空即可。",
              "source": "ai",
              "src_hash": "sha256:46a9e67e16e5",
              "doc_version": "2.0.0"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifiedFollowersResponse"
                }
              }
            }
          }
        },
        "x-doc": {
          "heading_zh": "获取用户认证关注者 GET /twitter/user/verifiedFollowers",
          "desc_en": "List the verified accounts that follow a given user, identified by user ID, in reverse-chronological order with cursor pagination.",
          "description_zh": "按用户 ID 获取关注某个用户的认证账号，按时间倒序排列并通过游标翻页。",
          "source": "ai",
          "src_hash": "sha256:9b9f9ffbab8a",
          "doc_version": "2.0.0"
        }
      }
    }
  }
}
