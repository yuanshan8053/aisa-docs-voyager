            "x-doc": {
              "desc_en": "Outcome marker of the request: success when mentions were returned, error otherwise.",
              "title_zh": "请求结果标记：成功返回提及推文为 success，否则为 error。",
              "source": "ai",
              "src_hash": "sha256:576998f7f1a9",
              "doc_version": "2.0.0"
            }
          },
          "message": {
            "type": "string",
            "x-doc": {
              "desc_en": "Human-readable message; carries the error detail when status is error.",
              "title_zh": "可读的提示信息；当 status 为 error 时承载错误详情。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          }
        }
      },
      "FollowRelationshipResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "following": {
                "type": "boolean",
                "x-doc": {
                  "desc_en": "Whether the source user follows the target user.",
                  "title_zh": "来源用户是否关注目标用户。",
                  "source": "ai",
                  "src_hash": "sha256:8e2bc3398639",
                  "doc_version": "2.0.0"
                }
              },
              "followed_by": {
                "type": "boolean",
                "x-doc": {
                  "desc_en": "Whether the target user follows the source user back.",
                  "title_zh": "目标用户是否回关来源用户。",
                  "source": "ai",
                  "src_hash": "sha256:8e2bc3398639",
                  "doc_version": "2.0.0"
                }
              }
            },
            "x-doc": {
              "desc_en": "The directional follow relationship between the two users.",
              "title_zh": "两个用户之间的关注关系方向。",
              "source": "ai",
              "src_hash": "sha256:8d46f256ede3",
              "doc_version": "2.0.0"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "success",
              "error"
            ],
            "x-doc": {
              "desc_en": "Outcome marker of the request: success when the relationship was returned, error otherwise.",
              "title_zh": "请求结果标记：成功返回关系为 success，否则为 error。",
              "source": "ai",
              "src_hash": "sha256:576998f7f1a9",
              "doc_version": "2.0.0"
            }
          },
          "message": {
            "type": "string",
            "x-doc": {
              "desc_en": "Human-readable message; carries the error detail when status is error.",
              "title_zh": "可读的提示信息；当 status 为 error 时承载错误详情。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          }
        }
      },
