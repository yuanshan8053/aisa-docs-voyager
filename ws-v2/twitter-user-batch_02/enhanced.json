      "User": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "x-doc": {
              "desc_en": "Object type tag identifying the entry as a user.",
              "title_zh": "对象类型标记，标识该条目为用户。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "userName": {
            "type": "string",
            "x-doc": {
              "desc_en": "The follower's @handle, unique across X/Twitter and used in profile URLs.",
              "title_zh": "关注者的 @ 用户名，在 X/Twitter 上唯一，用于资料页地址。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "url": {
            "type": "string",
            "x-doc": {
              "desc_en": "Web link to the follower's profile page.",
              "title_zh": "关注者资料页的网页链接。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "id": {
            "type": "string",
            "x-doc": {
              "desc_en": "Unique identifier of the follower.",
              "title_zh": "关注者的唯一标识。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "name": {
            "type": "string",
            "x-doc": {
              "desc_en": "The follower's display name shown on the profile.",
              "title_zh": "关注者在资料页展示的昵称。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "isBlueVerified": {
            "type": "boolean",
            "x-doc": {
              "desc_en": "Whether the follower holds a paid X (Twitter) Blue verification.",
              "title_zh": "关注者是否拥有付费的 X（Twitter）Blue 认证。",
              "source": "ai",
              "src_hash": "sha256:8e2bc3398639",
              "doc_version": "2.0.0"
            }
