            "type": "boolean",
            "x-doc": {
              "desc_en": "Whether the follower has created custom timelines.",
              "title_zh": "该关注者是否创建过自定义时间线。",
              "source": "ai",
              "src_hash": "sha256:8e2bc3398639",
              "doc_version": "2.0.0"
            }
          },
          "isTranslator": {
            "type": "boolean",
            "x-doc": {
              "desc_en": "Whether the follower participates in the Twitter translation program.",
              "title_zh": "该关注者是否参与 Twitter 翻译计划。",
              "source": "ai",
              "src_hash": "sha256:8e2bc3398639",
              "doc_version": "2.0.0"
            }
          },
          "mediaCount": {
            "type": "integer",
            "x-doc": {
              "desc_en": "Number of media items the follower has posted.",
              "title_zh": "该关注者发布过的媒体条目数。",
              "source": "ai",
              "src_hash": "sha256:644595857f56",
              "doc_version": "2.0.0"
            }
          },
          "statusesCount": {
            "type": "integer",
            "x-doc": {
              "desc_en": "Total number of tweets the follower has posted.",
              "title_zh": "该关注者发布过的推文总数。",
              "source": "ai",
              "src_hash": "sha256:644595857f56",
              "doc_version": "2.0.0"
            }
          },
          "withheldInCountries": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "x-doc": {
              "desc_en": "Country codes where the follower's account is withheld for legal reasons.",
              "title_zh": "因法律原因屏蔽该关注者账号的国家／地区代码列表。",
              "source": "ai",
              "src_hash": "sha256:cb839f650391",
              "doc_version": "2.0.0"
            }
          },
          "possiblySensitive": {
            "type": "boolean",
            "x-doc": {
              "desc_en": "Whether the follower's posts are flagged as potentially sensitive.",
              "title_zh": "该关注者的内容是否被标记为可能含敏感信息。",
              "source": "ai",
              "src_hash": "sha256:8e2bc3398639",
              "doc_version": "2.0.0"
            }
          },
          "pinnedTweetIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "x-doc": {
              "desc_en": "Identifiers of tweets the follower has pinned to the top of their profile.",
              "title_zh": "该关注者置顶在资料页顶部的推文标识列表。",
              "source": "ai",
              "src_hash": "sha256:cb839f650391",
              "doc_version": "2.0.0"
            }
          },
          "isAutomated": {
            "type": "boolean",
            "x-doc": {
              "desc_en": "Whether the account is labeled as an automated (bot) account.",
              "title_zh": "该账号是否被标记为自动化（机器人）账号。",
              "source": "ai",
              "src_hash": "sha256:8e2bc3398639",
              "doc_version": "2.0.0"
            }
          },
          "automatedBy": {
            "type": "string",
            "x-doc": {
              "desc_en": "Username of the person or entity managing the automated account.",
              "title_zh": "管理该自动化账号的个人或机构的用户名。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "unavailable": {
            "type": "boolean",
            "x-doc": {
              "desc_en": "Whether the follower's account is currently unavailable, for example suspended or deactivated.",
              "title_zh": "该关注者账号当前是否不可用，例如被封禁或停用。",
              "source": "ai",
              "src_hash": "sha256:8e2bc3398639",
              "doc_version": "2.0.0"
            }
          },
          "message": {
            "type": "string",
            "x-doc": {
              "desc_en": "Explanatory message returned when the account is unavailable.",
              "title_zh": "账号不可用时返回的说明信息。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "unavailableReason": {
            "type": "string",
            "x-doc": {
              "desc_en": "Reason code or text describing why the account is unavailable.",
              "title_zh": "描述账号不可用原因的代码或文字。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          }
        }
