  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/twitter/trends": {
      "get": {
        "tags": [
          "https://docs.twitterapi.io/api-reference/endpoint/get_trends"
        ],
        "summary": "Get Trends",
        "description": "Get trends by WOEID.",
        "parameters": [
          {
            "name": "woeid",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "The WOEID of the location. Example: 2418046.",
            "x-doc": {
