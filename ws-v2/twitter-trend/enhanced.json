{
  "openapi": "3.0.3",
  "info": {
    "title": "TwitterAPI Unified API",
    "version": "1.0.0",
    "description": "Unified OpenAPI 3.0 specification for TwitterAPI endpoints."
  },
  "servers": [
    {
      "url": "https://api.aisa.one/apis/v1"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Trend": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "x-doc": {
              "desc_en": "Display name of the trend.",
              "title_zh": "趋势的显示名称。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "target": {
            "type": "object",
            "properties": {
              "query": {
                "type": "string",
                "x-doc": {
                  "desc_en": "The search query string that opens this trend's results.",
                  "title_zh": "打开该趋势结果所用的搜索查询字符串。",
                  "source": "ai",
                  "src_hash": "sha256:38a346cadbd3",
                  "doc_version": "2.0.0"
                }
              }
            },
            "x-doc": {
              "desc_en": "The search target this trend resolves to.",
              "title_zh": "该趋势对应的搜索目标。",
              "source": "ai",
              "src_hash": "sha256:d1a08fc984c3",
              "doc_version": "2.0.0"
            }
          },
          "rank": {
            "type": "integer",
            "format": "int64",
            "x-doc": {
              "desc_en": "Position of the trend in the list, where a smaller number ranks higher.",
              "title_zh": "趋势在榜单中的名次，数字越小排名越靠前。",
              "source": "ai",
              "src_hash": "sha256:5d49b80d4233",
              "doc_version": "2.0.0"
            }
          },
          "meta_description": {
            "type": "string",
            "x-doc": {
              "desc_en": "Supplementary descriptive text for the trend, such as associated post volume or context.",
              "title_zh": "趋势的补充描述文本，如相关讨论量或背景信息。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          }
        }
      },
      "TrendsResponse": {
        "type": "object",
        "properties": {
          "trends": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Trend"
            },
            "x-doc": {
              "desc_en": "The list of trending topics for the requested location.",
              "title_zh": "所请求地点的热门趋势列表。",
              "source": "ai",
              "src_hash": "sha256:d2088c544304",
              "doc_version": "2.0.0"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "success",
              "error"
            ],
            "x-doc": {
              "desc_en": "Whether the request succeeded or errored.",
              "title_zh": "请求是成功还是出错。",
              "source": "ai",
              "src_hash": "sha256:576998f7f1a9",
              "doc_version": "2.0.0"
            }
          },
          "msg": {
            "type": "string",
            "x-doc": {
              "desc_en": "Accompanying message, typically the error detail when the request did not succeed.",
              "title_zh": "附带消息，通常是请求未成功时的错误详情。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          }
        }
      },
      "SpaceDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "x-doc": {
              "desc_en": "Identifier of the Space.",
              "title_zh": "Space 的标识。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "title": {
            "type": "string",
            "x-doc": {
              "desc_en": "Title of the Space.",
              "title_zh": "Space 的标题。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "state": {
            "type": "string",
            "x-doc": {
              "desc_en": "Current lifecycle state of the Space, such as whether it is scheduled, live, or ended.",
              "title_zh": "Space 当前的生命周期状态，如已排期、直播中或已结束。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "x-doc": {
              "desc_en": "When the Space was created.",
              "title_zh": "Space 的创建时间。",
              "source": "ai",
              "src_hash": "sha256:af1286acb313",
              "doc_version": "2.0.0"
            }
          },
          "scheduled_start": {
            "type": "string",
            "format": "date-time",
            "x-doc": {
              "desc_en": "When the Space is scheduled to start.",
              "title_zh": "Space 计划开始的时间。",
              "source": "ai",
              "src_hash": "sha256:af1286acb313",
              "doc_version": "2.0.0"
            }
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "x-doc": {
              "desc_en": "When the Space's record was last updated.",
              "title_zh": "Space 记录最近一次更新的时间。",
              "source": "ai",
              "src_hash": "sha256:af1286acb313",
              "doc_version": "2.0.0"
            }
          },
          "media_key": {
            "type": "string",
            "x-doc": {
              "desc_en": "Media key referencing the Space's audio stream.",
              "title_zh": "指向该 Space 音频流的媒体键。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          },
          "is_subscribed": {
            "type": "boolean",
            "x-doc": {
              "desc_en": "Whether the requesting user is subscribed to the Space.",
              "title_zh": "发起请求的用户是否已订阅该 Space。",
              "source": "ai",
              "src_hash": "sha256:8e2bc3398639",
              "doc_version": "2.0.0"
            }
          },
          "settings": {
            "type": "object",
            "properties": {
              "conversation_controls": {
                "type": "integer",
                "x-doc": {
                  "desc_en": "Coded value indicating who is permitted to participate in the conversation.\n[⚠️Note:源码未声明该整数各取值的含义，待研发确认。]",
                  "title_zh": "表示谁可参与对话的编码值。\n[⚠️批注:源码未声明该整数各取值的含义，待研发确认。]",
                  "source": "ai",
                  "src_hash": "sha256:644595857f56",
                  "doc_version": "2.0.0"
                }
              },
              "disallow_join": {
                "type": "boolean",
                "x-doc": {
                  "desc_en": "Whether new participants are blocked from joining the Space.",
                  "title_zh": "是否禁止新参与者加入该 Space。",
                  "source": "ai",
                  "src_hash": "sha256:8e2bc3398639",
                  "doc_version": "2.0.0"
                }
              },
              "is_employee_only": {
                "type": "boolean",
                "x-doc": {
                  "desc_en": "Whether the Space is restricted to employees only.",
                  "title_zh": "该 Space 是否仅限员工。",
                  "source": "ai",
                  "src_hash": "sha256:8e2bc3398639",
                  "doc_version": "2.0.0"
                }
              },
              "is_locked": {
                "type": "boolean",
                "x-doc": {
                  "desc_en": "Whether the Space is locked.",
                  "title_zh": "该 Space 是否已锁定。",
                  "source": "ai",
                  "src_hash": "sha256:8e2bc3398639",
                  "doc_version": "2.0.0"
                }
              },
              "is_muted": {
                "type": "boolean",
                "x-doc": {
                  "desc_en": "Whether the Space is muted for the requesting user.",
                  "title_zh": "该 Space 对发起请求的用户是否已静音。",
                  "source": "ai",
                  "src_hash": "sha256:8e2bc3398639",
                  "doc_version": "2.0.0"
                }
              },
              "is_space_available_for_clipping": {
                "type": "boolean",
                "x-doc": {
                  "desc_en": "Whether clips may be created from the Space.",
                  "title_zh": "是否允许从该 Space 制作剪辑。",
                  "source": "ai",
                  "src_hash": "sha256:8e2bc3398639",
                  "doc_version": "2.0.0"
                }
              },
              "is_space_available_for_replay": {
                "type": "boolean",
                "x-doc": {
                  "desc_en": "Whether a replay of the Space is available.",
                  "title_zh": "该 Space 是否提供回放。",
                  "source": "ai",
                  "src_hash": "sha256:8e2bc3398639",
                  "doc_version": "2.0.0"
                }
              },
              "no_incognito": {
                "type": "boolean",
                "x-doc": {
                  "desc_en": "Whether anonymous (incognito) listening is disallowed.",
                  "title_zh": "是否禁止匿名（隐身）收听。",
                  "source": "ai",
                  "src_hash": "sha256:8e2bc3398639",
                  "doc_version": "2.0.0"
                }
              },
              "narrow_cast_space_type": {
                "type": "integer",
                "x-doc": {
                  "desc_en": "Coded value indicating the Space's narrowcast type.\n[⚠️Note:源码未声明该整数各取值的含义，待研发确认。]",
                  "title_zh": "表示该 Space 定向广播类型的编码值。\n[⚠️批注:源码未声明该整数各取值的含义，待研发确认。]",
                  "source": "ai",
                  "src_hash": "sha256:644595857f56",
                  "doc_version": "2.0.0"
                }
              },
              "max_guest_sessions": {
                "type": "integer",
                "x-doc": {
                  "desc_en": "Maximum number of concurrent guest speaker sessions allowed.",
                  "title_zh": "允许的并发嘉宾发言会话数上限。",
                  "source": "ai",
                  "src_hash": "sha256:644595857f56",
                  "doc_version": "2.0.0"
                }
              },
              "max_admin_capacity": {
                "type": "integer",
                "x-doc": {
                  "desc_en": "Maximum number of admins the Space can have.",
                  "title_zh": "该 Space 可拥有的管理员数量上限。",
                  "source": "ai",
                  "src_hash": "sha256:644595857f56",
                  "doc_version": "2.0.0"
                }
              }
            },
            "x-doc": {
              "desc_en": "The Space's configuration settings.",
              "title_zh": "Space 的配置项。",
              "source": "ai",
              "src_hash": "sha256:ebe5de054bcc",
              "doc_version": "2.0.0"
            }
          },
          "stats": {
            "type": "object",
            "properties": {
              "total_replay_watched": {
                "type": "integer",
                "x-doc": {
                  "desc_en": "Total number of replay views.",
                  "title_zh": "回放观看的总次数。",
                  "source": "ai",
                  "src_hash": "sha256:644595857f56",
                  "doc_version": "2.0.0"
                }
              },
              "total_live_listeners": {
                "type": "integer",
                "x-doc": {
                  "desc_en": "Total number of live listeners.",
                  "title_zh": "实时收听的总人数。",
                  "source": "ai",
                  "src_hash": "sha256:644595857f56",
                  "doc_version": "2.0.0"
                }
              },
              "total_participants": {
                "type": "integer",
                "x-doc": {
                  "desc_en": "Total number of participants across the Space.",
                  "title_zh": "该 Space 的参与者总人数。",
                  "source": "ai",
                  "src_hash": "sha256:644595857f56",
                  "doc_version": "2.0.0"
                }
              }
            },
            "x-doc": {
              "desc_en": "Audience statistics for the Space.",
              "title_zh": "Space 的听众统计。",
              "source": "ai",
              "src_hash": "sha256:5c5465576936",
              "doc_version": "2.0.0"
            }
          },
          "creator": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "x-doc": {
                  "desc_en": "Identifier of the creator.",
                  "title_zh": "创建者的标识。",
                  "source": "ai",
                  "src_hash": "sha256:38a346cadbd3",
                  "doc_version": "2.0.0"
                }
              },
              "name": {
                "type": "string",
                "x-doc": {
                  "desc_en": "Display name of the creator.",
                  "title_zh": "创建者的显示名称。",
                  "source": "ai",
                  "src_hash": "sha256:38a346cadbd3",
                  "doc_version": "2.0.0"
                }
              },
              "userName": {
                "type": "string",
                "x-doc": {
                  "desc_en": "Handle (@username) of the creator.",
                  "title_zh": "创建者的用户名（@username）。",
                  "source": "ai",
                  "src_hash": "sha256:38a346cadbd3",
                  "doc_version": "2.0.0"
                }
              },
              "location": {
                "type": "string",
                "x-doc": {
                  "desc_en": "Location listed on the creator's profile.",
                  "title_zh": "创建者资料中填写的所在地。",
