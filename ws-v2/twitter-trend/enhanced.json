                  "src_hash": "sha256:38a346cadbd3",
                  "doc_version": "2.0.0"
                }
              },
              "url": {
                "type": "string",
                "x-doc": {
                  "desc_en": "Website URL listed on the creator's profile.",
                  "title_zh": "创建者资料中填写的网站链接。",
                  "source": "ai",
                  "src_hash": "sha256:38a346cadbd3",
                  "doc_version": "2.0.0"
                }
              },
              "description": {
                "type": "string",
                "x-doc": {
                  "desc_en": "Bio text on the creator's profile.",
                  "title_zh": "创建者资料中的简介文本。",
                  "source": "ai",
                  "src_hash": "sha256:38a346cadbd3",
                  "doc_version": "2.0.0"
                }
              },
              "protected": {
                "type": "boolean",
                "x-doc": {
                  "desc_en": "Whether the creator's account is protected (private).",
                  "title_zh": "创建者账号是否受保护（私密）。",
                  "source": "ai",
                  "src_hash": "sha256:8e2bc3398639",
                  "doc_version": "2.0.0"
                }
              },
              "isVerified": {
                "type": "boolean",
                "x-doc": {
                  "desc_en": "Whether the creator's account is verified.",
                  "title_zh": "创建者账号是否已认证。",
                  "source": "ai",
                  "src_hash": "sha256:8e2bc3398639",
                  "doc_version": "2.0.0"
                }
              },
              "isBlueVerified": {
                "type": "boolean",
                "x-doc": {
                  "desc_en": "Whether the creator holds a Twitter Blue verification.",
                  "title_zh": "创建者是否拥有 Twitter Blue 认证。",
                  "source": "ai",
                  "src_hash": "sha256:8e2bc3398639",
                  "doc_version": "2.0.0"
