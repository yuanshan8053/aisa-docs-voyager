              },
              "verifiedType": {
                "type": "string",
                "x-doc": {
                  "desc_en": "The kind of verification the creator's account holds.",
                  "title_zh": "创建者账号所持认证的类型。",
                  "source": "ai",
                  "src_hash": "sha256:38a346cadbd3",
                  "doc_version": "2.0.0"
                }
              },
              "followers": {
                "type": "integer",
                "x-doc": {
                  "desc_en": "Number of accounts following the creator.",
                  "title_zh": "关注该创建者的账号数。",
                  "source": "ai",
                  "src_hash": "sha256:644595857f56",
                  "doc_version": "2.0.0"
                }
              },
              "following": {
                "type": "integer",
                "x-doc": {
                  "desc_en": "Number of accounts the creator follows.",
                  "title_zh": "该创建者关注的账号数。",
                  "source": "ai",
                  "src_hash": "sha256:644595857f56",
                  "doc_version": "2.0.0"
                }
              },
              "favouritesCount": {
                "type": "integer",
                "x-doc": {
                  "desc_en": "Number of tweets the creator has liked.",
                  "title_zh": "该创建者点赞过的推文数。",
                  "source": "ai",
                  "src_hash": "sha256:644595857f56",
                  "doc_version": "2.0.0"
                }
              },
              "statusesCount": {
                "type": "integer",
                "x-doc": {
                  "desc_en": "Number of tweets the creator has posted.",
                  "title_zh": "该创建者发布的推文数。",
                  "source": "ai",
                  "src_hash": "sha256:644595857f56",
                  "doc_version": "2.0.0"
                }
              },
              "mediaCount": {
                "type": "integer",
                "x-doc": {
                  "desc_en": "Number of media items the creator has posted.",
                  "title_zh": "该创建者发布的媒体条目数。",
                  "source": "ai",
                  "src_hash": "sha256:644595857f56",
                  "doc_version": "2.0.0"
                }
              },
              "createdAt": {
                "type": "string",
                "format": "date-time",
                "x-doc": {
                  "desc_en": "When the creator's account was created.",
                  "title_zh": "创建者账号的注册时间。",
                  "source": "ai",
                  "src_hash": "sha256:af1286acb313",
                  "doc_version": "2.0.0"
                }
              },
              "coverPicture": {
                "type": "string",
                "x-doc": {
                  "desc_en": "URL of the creator's profile cover image.",
                  "title_zh": "创建者资料封面图的链接。",
                  "source": "ai",
                  "src_hash": "sha256:38a346cadbd3",
                  "doc_version": "2.0.0"
                }
              },
              "profilePicture": {
                "type": "string",
                "x-doc": {
                  "desc_en": "URL of the creator's profile avatar.",
                  "title_zh": "创建者头像的链接。",
                  "source": "ai",
                  "src_hash": "sha256:38a346cadbd3",
                  "doc_version": "2.0.0"
                }
              },
              "canDm": {
                "type": "boolean",
                "x-doc": {
                  "desc_en": "Whether the requesting user can send the creator a direct message.",
                  "title_zh": "发起请求的用户是否可以向该创建者发送私信。",
                  "source": "ai",
                  "src_hash": "sha256:8e2bc3398639",
                  "doc_version": "2.0.0"
                }
              },
              "affiliatesHighlightedLabel": {
                "type": "object",
                "x-doc": {
                  "desc_en": "Highlighted affiliation label shown on the creator's profile.",
                  "title_zh": "创建者资料上展示的关联机构高亮标签。",
                  "source": "ai",
                  "src_hash": "sha256:ff419ebbeba4",
                  "doc_version": "2.0.0"
                }
              },
              "isAutomated": {
                "type": "boolean",
                "x-doc": {
                  "desc_en": "Whether the creator's account is marked as automated (a bot).",
                  "title_zh": "创建者账号是否被标记为自动化（机器人）账号。",
                  "source": "ai",
                  "src_hash": "sha256:8e2bc3398639",
                  "doc_version": "2.0.0"
                }
              },
              "automatedBy": {
                "type": "string",
                "x-doc": {
                  "desc_en": "Identifier of the account that manages this automated account.",
                  "title_zh": "管理该自动化账号的账号标识。",
                  "source": "ai",
                  "src_hash": "sha256:38a346cadbd3",
                  "doc_version": "2.0.0"
                }
              }
            },
            "x-doc": {
              "desc_en": "Profile of the user who created the Space.",
              "title_zh": "创建该 Space 的用户资料。",
              "source": "ai",
              "src_hash": "sha256:f54046f298cc",
              "doc_version": "2.0.0"
            }
          }
        }
      },
      "SpaceDetailResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/SpaceDetail",
            "x-doc": {
              "desc_en": "The Space's detail payload.",
              "title_zh": "Space 的详情数据。",
              "source": "ai",
              "src_hash": "sha256:7e1c17cd0005",
              "doc_version": "2.0.0"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "success",
              "error"
            ],
            "x-doc": {
              "desc_en": "Whether the request succeeded or errored.",
              "title_zh": "请求是成功还是出错。",
              "source": "ai",
              "src_hash": "sha256:576998f7f1a9",
              "doc_version": "2.0.0"
            }
          },
          "msg": {
            "type": "string",
            "x-doc": {
              "desc_en": "Accompanying message, typically the error detail when the request did not succeed.",
              "title_zh": "附带消息，通常是请求未成功时的错误详情。",
              "source": "ai",
              "src_hash": "sha256:38a346cadbd3",
              "doc_version": "2.0.0"
            }
          }
